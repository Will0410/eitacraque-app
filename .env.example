# ─────────────────────────────────────────────────────────
# API (apps/api)
# ─────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3333
API_HOST=0.0.0.0
WEB_ORIGIN=http://localhost:5173

# Postgres
DATABASE_URL=postgresql://eitacraque:eitacraque@localhost:5432/eitacraque?schema=public

# Redis (cache + BullMQ)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# MUX (vídeo)
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=

# Grok (xAI) — análise de IA
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-2-vision-latest

# AWS S3 (backups, thumbnails, anexos)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=eitacraque-assets

# E-mail (SMTP) — verificação e notificações
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM="EitaCraque <noreply@eitacraque.app>"

# ─────────────────────────────────────────────────────────
# Web (apps/web)
# ─────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3333
VITE_MUX_ENV_KEY=
