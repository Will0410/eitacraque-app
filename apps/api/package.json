{
  "name": "@eitacraque/api",
  "version": "0.1.0",
  "private": true,
  "description": "EitaCraque API — NestJS backend",
  "scripts": {
    "dev": "npm run build && dotenv -e ../../.env -- nest start --watch",
    "build": "nest build",
    "start": "dotenv -e ../../.env -- node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "prisma:generate": "dotenv -e ../../.env -- prisma generate",
    "prisma:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "prisma:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "prisma:studio": "dotenv -e ../../.env -- prisma studio",
    "prisma:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts"
  },
  "dependencies": {
    "@eitacraque/shared": "*",
    "@mux/mux-node": "^9.0.1",
    "@nestjs/common": "^10.4.6",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.6",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.6",
    "@nestjs/swagger": "^8.0.5",
    "@nestjs/throttler": "^6.2.1",
    "@prisma/client": "^5.22.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.27.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.7",
    "@nestjs/testing": "^10.4.6",
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "@types/passport-jwt": "^4.0.1",
    "dotenv-cli": "^7.4.2",
    "prisma": "^5.22.0",
    "ts-loader": "^9.5.1",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
