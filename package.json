{
  "name": "eitacraque",
  "version": "0.1.0",
  "private": true,
  "description": "EitaCraque — rede social para olheiros de futebol",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:api dev:web",
    "dev:api": "npm --workspace @eitacraque/api run dev",
    "dev:web": "npm --workspace @eitacraque/web run dev",
    "build": "npm-run-all build:shared build:api build:web",
    "build:shared": "npm --workspace @eitacraque/shared run build",
    "build:api": "npm --workspace @eitacraque/api run build",
    "build:api:prod": "npm --workspace @eitacraque/api run prisma:generate && npm --workspace @eitacraque/api run build",
    "build:web": "npm --workspace @eitacraque/web run build",
    "lint": "npm-run-all -p lint:api lint:web",
    "lint:api": "npm --workspace @eitacraque/api run lint",
    "lint:web": "npm --workspace @eitacraque/web run lint",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "db:migrate": "npm --workspace @eitacraque/api run prisma:migrate",
    "db:studio": "npm --workspace @eitacraque/api run prisma:studio"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
